FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SESSION_SECRET=replace_with_a_long_random_string

# AscentChat uses a separate Firebase project (asenchata).
# Without these, admin cannot see chat users and broadcasts won't reach chat.
CHAT_FIREBASE_PROJECT_ID=asenchata
CHAT_FIREBASE_CLIENT_EMAIL=your_asenchata_service_account@asenchata.iam.gserviceaccount.com
CHAT_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
